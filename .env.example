# Connection string naar je Postgres-database.
# Op Vercel wordt deze automatisch toegevoegd wanneer je in het tabblad
# "Storage" een Neon Postgres-database aan het project koppelt.
#
# Voor lokaal testen: kopieer dit bestand naar .env.local en vul de waarde in.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
